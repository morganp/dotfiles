# Run Stow Command to link config files

dotfiles_dir="$HOME/dotfiles"

cd "$dotfiles_dir/config"
#stow git --dotfiles -t ~/
stow input --dotfiles -t ~/
stow screen --dotfiles -t ~/
#stow tmux --dotfiles -t ~/ Obeys $XDG_CONFIG_HOME
stow ctags --dotfiles -t ~/

mkdir -p $HOME/.config/git
stow git  -t  $HOME/.config/git

mkdir -p $HOME/.config/ghostty
stow ghostty  -t  $HOME/.config/ghostty

mkdir -p $HOME/.config/karabiner
stow karabiner  -t  $HOME/.config/karabiner

# skillbook tracks main (branch set in .gitmodules); --remote always pulls latest, never a pin
git -C "$dotfiles_dir" submodule update --remote --init config/shared/skillbook

mkdir -p ~/.codex
./codex/install_config.sh
if [ -L "$HOME/.codex/skills" ] || [ ! -e "$HOME/.codex/skills" ]; then
    ln -sfn "$HOME/dotfiles/config/shared/skillbook" "$HOME/.codex/skills"
else
    mv "$HOME/.codex/skills" "$HOME/.codex/skills.bak-before-shared-skillbook"
    ln -s "$HOME/dotfiles/config/shared/skillbook" "$HOME/.codex/skills"
fi

mkdir -p ~/.claude
stow claude --dotfiles -t ~/.claude/
# settings.json is OS-specific and excluded from stow (see config/claude/.stow-local-ignore).
# macOS keeps the full config (caveman hooks, swift-lsp); Linux uses an adapted variant
# with no macOS-absolute hook paths and no skipDangerousMode.
if [[ "$(uname)" == "Darwin" ]]; then
  ln -sfn "$HOME/dotfiles/config/claude/settings.json"       "$HOME/.claude/settings.json"
else
  ln -sfn "$HOME/dotfiles/config/claude/settings.linux.json" "$HOME/.claude/settings.json"
fi
ln -sfn "$HOME/dotfiles/config/shared/skillbook" "$HOME/.claude/skills"
