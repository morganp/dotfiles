"~/.vimrc should be a link here or contain the following:
"so ~/dotfiles/dot-vimrc_clean

" Core UI
syntax on
filetype plugin indent on

" Number lines for debug
set number

" Map the ctrl-shift-C to vim Copy
:map <C-S-z> u
:map <C-S-x> "+x
:map <C-S-c> "+y
:map <C-S-v> "+gP

" Tab settings
set expandtab           " spaces are used instead of tabs
set tabstop=2           " number of spaces inserted when tab is hit
set shiftwidth=2        " used with autoindent (should equal tabstop)
set softtabstop=2       " if set below tabstop will insert this many spaces 
set shiftround          " round indents to a multiple of shiftwidth
set autoindent
set smartindent

"http://amix.dk/vim/vimrc.txt
" No annoying sound on errors
if has('patch-7.4.793')
  set belloff=all
else
  set noerrorbells
  set novisualbell
  set t_vb=
endif
set tm=500

" Navigation/search quality-of-life
set ignorecase
set smartcase
set incsearch
set hlsearch
set scrolloff=3

" Buffers, clipboard, undo
set hidden
set clipboard=unnamedplus
set updatetime=300
set undofile
set undodir=~/.vim/undo
